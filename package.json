{
  "name": "1-blue",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "create:app": "node tools/create-app/index.mjs",
    "ui:add": "pnpm --filter @1-blue/ui ui:add",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md,css}\"",
    "clean": "rm -rf .turbo && find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + && find . -name '.next' -type d -prune -exec rm -rf '{}' + && pnpm install",

    "dev:date-calculator": "pnpm --filter web-date-calculator dev",
    "dev:paper-lottery": "pnpm --filter web-paper-lottery dev",
    "dev:daily-doodle": "pnpm --filter web-daily-doodle dev",
    "dev:daily-deduction": "pnpm --filter web-daily-deduction dev",
    "dev:siheomform": "pnpm --filter web-siheomform dev",
    "dev:sseoltalk": "pnpm --filter web-sseoltalk dev"
  },
  "devDependencies": {
    "@1-blue/eslint-config": "workspace:*",
    "@1-blue/typescript-config": "workspace:*",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20"
  }
}
