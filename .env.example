# Monorepo env index — copy template .env.example into each generated app.
#
#   apps/web-{slug}/.env.example  → cp .env.local  (web-static / web-api)
#   apps/_template-ait/ENV.md     (AIT — no .env)
#   apps/_template-expo/ENV.md    (Expo — app.json)
#
# Ports: 7000–7599 (Next.js web/ait), 8000–8599 (Expo Metro). Assigned by `pnpm create:app`.

# --- web-static / web-api (see apps/web-{slug}/.env.example) ---

NEXT_PUBLIC_SITE_URL=http://localhost:7000
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# --- web-api only (Supabase) ---

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
